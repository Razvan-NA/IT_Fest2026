<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp"
    android:background="#FFFFFF">

    <!-- Timer card roșu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@drawable/rounded_red_card"
        android:padding="16dp"
        android:layout_marginBottom="24dp">

        <TextView
            android:text="ALERTĂ SE TRIMITE ÎN"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="#FFCCCC"
            android:letterSpacing="0.15"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvCountdown"
            android:text="15"
            android:textSize="52sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- Titlu -->
    <TextView
        android:text="Cădere detectată!"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#B71C1C"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="10dp"/>

    <!-- Subtitlu -->
    <TextView
        android:text="Alerta se trimite automat dacă nu răspunzi."
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"/>

    <!-- Buton SUNT BINE -->
    <Button
        android:id="@+id/btnImOk"
        android:text="SUNT BINE! ✓"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:backgroundTint="#2E7D32"
        android:stateListAnimator="@null"/>

    <Button
        android:id="@+id/btnSendAlert"
        android:text="🆘 TRIMITE ALERTA ACUM"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:backgroundTint="#B71C1C"
        android:stateListAnimator="@null"
        android:layout_marginTop="12dp"/>

</LinearLayout>