<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="#FFFFFF"
    android:clipChildren="false"
    android:clipToPadding="false">

    <Space
        android:layout_width="match_parent"
        android:layout_height="60dp"
        />
    <!-- Titlu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="44dp"
        android:background="@drawable/rounded_red_card"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"
            android:letterSpacing="0.15"
            android:text="ALERTĂ SE TRIMITE ÎN"
            android:textColor="#FFCCCC"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15"
            android:textColor="#FFFFFF"
            android:textSize="52sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:text="Cădere detectată!"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#B71C1C"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="10dp"/>

    <!-- Subtitlu -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginBottom="24dp"
        android:gravity="center"
        android:text="Alerta se trimite automat dacă nu răspunzi."
        android:textColor="#000000"
        android:textSize="17sp"
        android:textStyle="bold" />

    <Space
        android:layout_width="match_parent"
        android:layout_height="140dp"
        />

    <!-- Inele sonar + buton -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_marginBottom="32dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <View
            android:id="@+id/ring1"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@drawable/rounded_green_btn"
            android:layout_gravity="center"/>

        <View
            android:id="@+id/ring2"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@drawable/rounded_green_btn"
            android:layout_gravity="center"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnImOk"
            android:text="SUNT BINE! ✓"
            android:textSize="40sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:background="@drawable/rounded_green_btn"
            android:backgroundTint="@null"
            android:stateListAnimator="@null"
            android:layout_gravity="center"/>

    </FrameLayout>

</LinearLayout>